<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardElevation="0dp"
   >
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"

    >
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- 日期 + 星期 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:paddingTop="4dp"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1145-1-4"
                android:textColor="@android:color/black"
                android:textSize="16sp" />

            <TextView
                android:paddingTop="4dp"
                android:id="@+id/tv_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="周日"
                android:textColor="@android:color/black"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 白天/夜间天气 -->
        <TextView
            android:id="@+id/tv_weather_day_night"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="晴 / 多云"
            android:textSize="14sp" />

        <!-- 最高温/最低温 -->
        <TextView
            android:paddingTop="4dp"
            android:id="@+id/tv_temp_max_min"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="25℃ / 18℃"
            android:textSize="14sp" />

        <!-- 风向风力 -->
        <TextView
            android:paddingTop="4dp"
            android:id="@+id/tv_wind_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="东风3级 / 东北风2级"
            android:textColor="@android:color/black"
            android:textSize="12sp" />

        <!-- 日出日落 -->
        <TextView
            android:paddingTop="4dp"
            android:id="@+id/tv_sunrise_sunset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="日出：06:30 日落：18:30"
            android:textColor="@android:color/black"
            android:textSize="12sp" />

    </LinearLayout>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:id="@+id/iv_random"
        />
    </LinearLayout>

</androidx.cardview.widget.CardView>